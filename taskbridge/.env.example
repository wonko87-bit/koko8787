# ============================================================
# TaskBridge – 환경 변수 설정
# 이 파일을 .env 로 복사한 뒤 값을 채워주세요.
# ============================================================

# Google OAuth 2.0
# https://console.cloud.google.com/apis/credentials 에서 발급
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Todoist OAuth 2.0
# https://developer.todoist.com/appconsole.html 에서 발급
TODOIST_CLIENT_ID=your-todoist-client-id
TODOIST_CLIENT_SECRET=your-todoist-client-secret

# 서버 포트 (선택, 기본값 8000)
PORT=8000
